# Copy this file to .env only if you want to customize values.
# By default, docker compose will still run without .env using fallback values.

POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_DB=autopoiesis_db

SECRET_KEY=autopoiesis_super_secret_dev_key

# Timezone (Bolivia)
TZ=America/La_Paz

# Host ports
FRONTEND_PORT=3000
BACKEND_PORT=5000
DB_PORT=5433
PGADMIN_PORT=5051

PGADMIN_DEFAULT_EMAIL=admin@autopoiesis.com
PGADMIN_DEFAULT_PASSWORD=admin
